\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{preamble-legacy}[Legacy preamble — v1 = kpfonts era, v2 = newpx era (default)]

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Options
\newif\iflegacy@vone  % v1 = kpfonts era; default is v2

\DeclareOption{v1}{\legacy@vonetrue}
\DeclareOption{v2}{}
\ProcessOptions\relax

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Core packages (shared)
\iflegacy@vone\RequirePackage[utf8]{inputenc}\fi
\RequirePackage[margin=1in]{geometry}
\RequirePackage{graphicx}
\RequirePackage{xparse}

\RequirePackage{amsmath,amssymb,amsthm,mathtools}
\iflegacy@vone
  \RequirePackage{amsfonts,mathrsfs,bbm}
\else
  \RequirePackage{fix-cm,bm,dsfont}
\fi

\RequirePackage[shortlabels]{enumitem}
\RequirePackage{algorithm}
\RequirePackage{algpseudocode}
\RequirePackage{multicol}
\RequirePackage{marvosym}
\RequirePackage{fancyhdr}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Fonts
\iflegacy@vone
  \RequirePackage{kpfonts}
  \RequirePackage[scale=0.85]{sourcecodepro}
  \RequirePackage{minted}
  \setminted{style=gruvbox-light}
\else
  \RequirePackage{newpxtext,newpxmath}
  \providecommand{\symbf}{\boldsymbol}
  \RequirePackage{hyperref}
  \hypersetup{colorlinks=true, linkcolor=cyan, filecolor=red, urlcolor=blue}
\fi

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Environment variable handling (shared)
\ExplSyntaxOn
\NewDocumentCommand{\getenv}{om}
{
  \sys_get_shell:nnN { kpsewhich ~ --var-value ~ #2 } { } \l_tmpa_tl
  \tl_trim_spaces:N \l_tmpa_tl
  \IfNoValueTF { #1 }
  { \tl_use:N \l_tmpa_tl }
  { \tl_set_eq:NN #1 \l_tmpa_tl }
}
\ExplSyntaxOff
\getenv[\AUTHOR]{AUTHOR}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Page styles
\iflegacy@vone
  \pagestyle{fancy}
  \fancyhf{}
  \graphicspath{{./images/}}
\else
  \setlength{\headheight}{13.59999pt}
  \fancypagestyle{fancydefault}{
    \fancyhf{}
    \fancyhead[L]{\nouppercase{\leftmark}}
    \fancyhead[R]{\thepage}
    \renewcommand{\headrulewidth}{0.4pt}
    \renewcommand{\footrulewidth}{0pt}
  }
  \fancypagestyle{cover}{
    \fancyhf{}
    \renewcommand{\headrulewidth}{0pt}
    \renewcommand{\footrulewidth}{0pt}
  }
  \pagestyle{fancydefault}
  \newif\ifcoverpage
  \AtBeginDocument{
    \ifcoverpage\thispagestyle{cover}\else\thispagestyle{fancydefault}\fi
  }
\fi

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Title and subtitle (v2 only)
\iflegacy@vone\else
  \NewDocumentCommand{\subtitle}{m}{\gdef\@subtitle{#1}}
  \providecommand{\@subtitle}{}
  \RenewDocumentCommand{\maketitle}{}{
    \ifcoverpage
      \thispagestyle{cover}
      \begin{titlepage}
        \vspace*{\fill}
        \begin{center}
          {\LARGE\bfseries \@title \par}
          \ifx\@subtitle\@empty\else\vskip0.8em{\large\itshape \@subtitle \par}\fi
          \vskip1.2em {\large \@author \par}
          \vskip0.8em {\normalsize \@date \par}
        \end{center}
        \vspace*{\fill}
        \clearpage
      \end{titlepage}
    \else
      \begin{center}
        {\LARGE\bfseries \@title \par}
        \ifx\@subtitle\@empty\else\vskip0.5em{\large\itshape \@subtitle \par}\fi
        \vskip1em {\large \@author \par}
        \vskip0.5em {\normalsize \@date \par}
      \end{center}
      \vskip2em
    \fi
  }
\fi

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Mathematical operators

\iflegacy@vone
  \DeclareMathOperator{\cis}{cis}
  \DeclareMathOperator{\re}{Re}
  \DeclareMathOperator*{\argmax}{arg\,max}
  \DeclareMathOperator*{\argmin}{arg\,min}
  \renewcommand{\dim}{\mathrm{dim}}
  \renewcommand{\ker}{\mathrm{Ker}}
  \newcommand{\im}{\mathrm{Im}}
  \newcommand{\tr}{\mathrm{tr}}
  \newcommand{\id}{\mathrm{id}}
  \newcommand{\Id}{\mathrm{Id}}
\else
  \let\Re\relax \let\Im\relax
  \DeclareMathOperator{\Re}{Re}
  \DeclareMathOperator{\Im}{Im}
  \DeclareMathOperator{\Rk}{rk}
  \DeclareMathOperator{\tr}{tr}
  \DeclareMathOperator{\Id}{Id}
  \DeclareMathOperator{\id}{id}
\fi

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Delimiters (v2 only)
\iflegacy@vone\else
  \DeclarePairedDelimiter{\parens}{(}{)}
  \DeclarePairedDelimiter{\bracks}{[}{]}
  \DeclarePairedDelimiter{\braces}{\lbrace}{\rbrace}
  \DeclarePairedDelimiterX{\set}[2]{\lbrace}{\rbrace}{#1 \;\delimsize\vert\; #2}
  \DeclarePairedDelimiter{\ang}{\langle}{\rangle}
  \DeclarePairedDelimiter{\abs}{\lvert}{\rvert}
  \DeclarePairedDelimiter{\norm}{\lVert}{\rVert}
  \DeclarePairedDelimiter{\ceil}{\lceil}{\rceil}
  \DeclarePairedDelimiter{\floor}{\lfloor}{\rfloor}

  \DeclarePairedDelimiterX{\inner@delim}[2]{\langle}{\rangle}{#1,\,#2}
  \NewDocumentCommand{\inner}{s m m o}{%
    \IfBooleanTF{#1}{\inner@delim*{#2}{#3}}{\inner@delim{#2}{#3}}%
    \IfValueT{#4}{_{#4}}%
  }
  \NewDocumentCommand{\normp}{smm}{
    \IfBooleanTF{#1}{\norm*{#2}_{#3}}{\norm{#2}_{#3}}
  }
  \NewDocumentCommand{\Lp}{m o}{
    \IfNoValueTF{#2}{L^{#1}}{L^{#1}\!\left(#2\right)}
  }
\fi

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Probability and statistics

\newcommand{\E}{\mathbb{E}}

\iflegacy@vone\else
  \let\Pr\relax
  \newcommand{\Pr}{\mathbb{P}}
  \newcommand{\Var}{\mathbf{Var}}
  \newcommand{\Cov}{\mathbf{Cov}}
\fi

