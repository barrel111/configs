  \NewDocumentCommand{\N}{}{\mathbb{N}}
  \NewDocumentCommand{\Z}{}{\mathbb{Z}}
  \NewDocumentCommand{\Q}{}{\mathbb{Q}}
  \NewDocumentCommand{\R}{}{\mathbb{R}}
  \NewDocumentCommand{\C}{}{\mathbb{C}}
  \providecommand{\Empty}{\varnothing}
\fi

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Miscellaneous notation

\iflegacy@vone
  \newcommand{\Lim}[1]{\raisebox{0.5ex}{\scalebox{0.8}{$\displaystyle \lim_{#1}\;$}}}
  \newcommand{\inv}{^{-1}}
  \newcommand{\vv}[1]{\boldsymbol{#1}}
\else
  \NewDocumentCommand{\Lim}{m}{\lim\limits_{#1}}
  \NewDocumentCommand{\inv}{}{{}^{-1}}
  \RenewDocumentCommand{\vv}{m}{\symbf{#1}}
  \newcommand{\eps}{\varepsilon}
  \newcommand{\del}{\delta}
  \newcommand{\lam}{\lambda}
  \NewDocumentCommand{\defeq}{}{\vcentcolon=}
  \NewDocumentCommand{\eqdef}{}{=\vcentcolon}
\fi

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Complexity notation (v2 only)
\iflegacy@vone\else
  \NewDocumentCommand{\class}{m}{\mathsf{#1}}
  \NewDocumentCommand{\Otilde}{m}{\tilde{\mathcal{O}}\parens{#1}}
  \NewDocumentCommand{\Ohat}{m}{\widehat{\mathcal{O}}\parens{#1}}
  \NewDocumentCommand{\Omegahat}{m}{\widehat{\Omega}\parens{#1}}
  \NewDocumentCommand{\bigO}{m}{\mathcal{O}\parens{#1}}
  \NewDocumentCommand{\bigTheta}{m}{\Theta\parens{#1}}
  \NewDocumentCommand{\bigOmega}{m}{\Omega\parens{#1}}
  \NewDocumentCommand{\littleo}{m}{o\parens{#1}}
  \NewDocumentCommand{\littleomega}{m}{\omega\parens{#1}}
  \DeclareMathOperator{\poly}{poly}
  \DeclareMathOperator{\polylog}{polylog}
  \DeclareMathOperator{\quasipoly}{quasipoly}
  \NewDocumentCommand{\simconst}{}{\mathrel{\asymp}}
  \NewDocumentCommand{\lt}{m}{\littleo{#1}}
  \NewDocumentCommand{\st}{m}{\Otilde{#1}}
  \NewDocumentCommand{\gt}{m}{\littleomega{#1}}
  \NewDocumentCommand{\polytime}{}{\class{P}}
  \NewDocumentCommand{\NPtime}{}{\class{NP}}
  \NewDocumentCommand{\BPPtime}{}{\class{BPP}}
  \NewDocumentCommand{\EXPtime}{}{\class{EXP}}
\fi

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Theorem environments

\theoremstyle{plain}
\iflegacy@vone
  \newtheorem{theorem}{Theorem}[section]
\else
  \newtheorem{theorem}{Theorem}
\fi
\newtheorem{lemma}[theorem]{Lemma}
\newtheorem{corollary}[theorem]{Corollary}
\newtheorem*{theorem*}{Theorem}
\newtheorem*{lemma*}{Lemma}

\iflegacy@vone
  \newtheorem{proposition}[theorem]{Proposition}
\else
  \newtheorem{claim}[theorem]{Claim}
\fi

\theoremstyle{definition}
\newtheorem{definition}[theorem]{Definition}
\newtheorem{example}[theorem]{Example}
\newtheorem*{definition*}{Definition}
\newtheorem*{example*}{Example}

\iflegacy@vone
  \newtheorem{conjecture}{Conjecture}[section]
  \newtheorem{question}{Question}[section]
  \newtheorem*{question*}{Question}
\else
  \newtheorem{notation}[theorem]{Notation}
  \newtheorem*{notation*}{Notation}
\fi

\theoremstyle{remark}
\newtheorem*{remark}{Remark}

\iflegacy@vone
  \newtheorem*{claim}{Claim}
  \newtheorem*{note}{Note}
  \newtheorem*{exercise}{Exercise}
  \newtheorem*{notation*}{Notation}
\fi

\renewcommand*{\proofname}{Proof}

% Theorem numbering toggles (v2 only)
\iflegacy@vone\else
  \newcommand{\theorembysection}{%
    \counterwithout{theorem}{problem}%
    \counterwithin{theorem}{section}%
  }
  \newcommand{\theorembyproblem}{%
    \counterwithout{theorem}{section}%
    \counterwithin{theorem}{problem}%
  }
  \newcommand{\thmlabel}[1]{\label{thm:#1}}
  \newcommand{\lemlabel}[1]{\label{lem:#1}}
  \newcommand{\deflabel}[1]{\label{def:#1}}

  \def\th@plain{\thm@notefont{\scshape}\itshape}
  \def\th@definition{\thm@notefont{\scshape}\normalfont}
  \def\th@remark{\thm@notefont{\scshape}\normalfont}
  \def\popQED{\par\nobreak\hfill\qedsymbol\@endpefalse\par}
\fi

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Algorithm customizations (v1 only)
\iflegacy@vone
  \renewcommand{\Call}[1]{\textbf{Call }#1}
  \algrenewcommand\algorithmicrequire{\textbf{assuming:}}
\fi

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Breakable algorithm environment (shared)
\newenvironment{breakablealgorithm}
{% \begin{breakablealgorithm}
  \begin{center}
    \refstepcounter{algorithm}
    \hrule height.8pt depth0pt \kern2pt
    \renewcommand{\caption}[2][\relax]{%
      {\raggedright\textbf{\fname@algorithm~\thealgorithm} ##2\par}%
      \ifx\relax##1\relax
        \addcontentsline{loa}{algorithm}{\protect\numberline{\thealgorithm}##2}%
      \else
        \addcontentsline{loa}{algorithm}{\protect\numberline{\thealgorithm}##1}%
      \fi
      \kern2pt\hrule\kern2pt
    }
}{% \end{breakablealgorithm}
    \kern2pt\hrule\relax
  \end{center}
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Problem environment

\newcounter{problem}[section]
\iflegacy@vone
  \newenvironment{problem}[1][]{\refstepcounter{problem}\par\medskip
    \noindent{\fontsize{11}{13}\selectfont\textbf{Problem~\theproblem. #1}}\rmfamily}{\medskip}
\else
  \renewcommand{\theproblem}{\arabic{problem}.}
  \NewDocumentEnvironment{problem}{o}
  {
    \refstepcounter{problem}
    \par\vspace{0.5\baselineskip}
    \noindent\large\textbf{Problem~\theproblem}%
    \IfValueT{#1}{\textbf{ (#1)}}%
    \par\nobreak\vspace{0.25\baselineskip}\noindent\normalsize
  }
  { \par\vspace{0.5\baselineskip} }
\fi

\iflegacy@vone\else\theorembysection\fi

